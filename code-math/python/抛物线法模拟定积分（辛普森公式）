expr = input("请输入被积函数 f(x)：")  # 例如 x**2
a = float(input("输入下限 a："))
b = float(input("输入上限 b："))
n = int(input("输入偶数 n："))

def f(x):
    return eval(expr, {"x": x})

h = (b - a) / n
total = f(a) + f(b)

for i in range(1, n):
    x = a + i * h
    if i % 2 == 0:
        total += 2 * f(x)
    else:
        total += 4 * f(x)

result = total * h / 3
print("积分近似值为：", result)
